---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Webbiecorn Lab — Digitale producten en experimenten">
  <style>
    .lab-hero-bg {
      position: absolute; inset: 0;
      background: radial-gradient(ellipse at 70% 20%, rgba(217,43,75,0.12) 0%, transparent 55%),
                  radial-gradient(ellipse at 20% 80%, rgba(217,43,75,0.07) 0%, transparent 50%);
    }
    .lab-filter-row { display: flex; gap: 0.6rem; flex-wrap: wrap; margin: 2.5rem 0 3rem; }
    .lab-filter-btn {
      padding: 0.5rem 1.1rem; border-radius: 100px;
      border: 1px solid rgba(255,255,255,0.1); background: transparent;
      color: rgba(255,255,255,0.5); font-family: 'Outfit', sans-serif;
      font-size: 0.8rem; font-weight: 700; cursor: pointer; transition: all 0.2s;
    }
    .lab-filter-btn:hover { color: #fff; border-color: rgba(255,255,255,0.25); }
    .lab-filter-btn.active { background: var(--red); border-color: var(--red); color: #fff; }
    .lab-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem; }
    .lab-card {
      background: var(--black-card); border: 1px solid var(--border);
      border-radius: 16px; overflow: hidden;
      text-decoration: none; color: var(--white);
      transition: transform 0.3s, border-color 0.3s, box-shadow 0.3s;
      position: relative; display: flex; flex-direction: column;
    }
    .lab-card::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
      background: var(--red); transform: scaleX(0); transform-origin: left; transition: transform 0.35s ease;
    }
    .lab-card:hover { transform: translateY(-6px); border-color: rgba(217,43,75,0.4); box-shadow: 0 20px 60px rgba(217,43,75,0.12); }
    .lab-card:hover::before { transform: scaleX(1); }
    .lab-card-thumb { width: 100%; aspect-ratio: 16/9; background: var(--black-mid); overflow: hidden; position: relative; }
    .lab-card-thumb img { width:100%;height:100%;object-fit:cover;transition:transform 0.6s ease; }
    .lab-card:hover .lab-card-thumb img { transform: scale(1.06); }
    .lab-card-thumb-overlay { position:absolute;inset:0;background:linear-gradient(to top,rgba(10,10,10,0.7),transparent 50%); }
    .lab-card-badge {
      position:absolute;top:1rem;left:1rem;
      font-size:0.62rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;
      padding:0.3rem 0.7rem;border-radius:100px;
      background:rgba(10,10,10,0.85);border:1px solid rgba(255,255,255,0.12);
      color:rgba(255,255,255,0.7);backdrop-filter:blur(8px);
    }
    .lab-card-body { padding: 1.5rem; flex: 1; display: flex; flex-direction: column; }
    .lab-card-name { font-size: 1.1rem; font-weight: 700; margin-bottom: 0.45rem; }
    .lab-card-desc { font-size: 0.84rem; color: rgba(255,255,255,0.5); line-height: 1.65; margin-bottom: 1rem; flex: 1; }
    .lab-card-chips { display: flex; flex-wrap: wrap; gap: 0.4rem; }
    .lab-chip {
      font-size:0.65rem;font-weight:700;letter-spacing:0.5px;padding:0.2rem 0.6rem;
      background:rgba(217,43,75,0.1);border:1px solid rgba(217,43,75,0.2);
      border-radius:100px;color:rgba(255,255,255,0.6);
    }
    .lab-card-link {
      display:inline-flex;align-items:center;gap:0.4rem;
      margin-top:1rem;color:var(--red);font-size:0.8rem;font-weight:700;transition:gap 0.2s;
    }
    .lab-card:hover .lab-card-link { gap:0.65rem; }
    .lab-stats {
      display: flex; gap: 3rem; flex-wrap: wrap;
      margin-top: 3rem; padding-top: 2.5rem; border-top: 1px solid rgba(255,255,255,0.07);
    }
    .lab-stat-nr { font-size: 2rem; font-weight: 900; color: var(--red); line-height: 1; }
    .lab-stat-label { font-size: 0.72rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,0.35); margin-top: 0.3rem; }
  </style>

<section class="page-hero">
  <div class="lab-hero-bg"></div>
  <div class="container">
    <p class="section-label reveal">Webbiecorn Lab</p>
    <h1 class="page-hero-title reveal reveal-delay-1">Alles wat we<br/><em>bouwen en testen.</em></h1>
    <p class="page-hero-sub reveal reveal-delay-2">Van maatwerk PWA's tot AI-tools en concepten. Dit is het overzicht van producten die we bouwden, lançeerden en doorontwikkelen.</p>
    <div class="lab-stats">
      <div class="lab-stat-item reveal reveal-delay-1">
        <div class="lab-stat-nr">6+</div>
        <div class="lab-stat-label">Live producten</div>
      </div>
      <div class="lab-stat-item reveal reveal-delay-2">
        <div class="lab-stat-nr">3</div>
        <div class="lab-stat-label">Actieve klanten</div>
      </div>
      <div class="lab-stat-item reveal reveal-delay-3">
        <div class="lab-stat-nr">∞</div>
        <div class="lab-stat-label">Iteraties</div>
      </div>
    </div>
  </div>
</section>

<section style="padding:4rem 2rem 7rem;background:var(--black)">
  <div class="container">
    <div class="lab-filter-row reveal">
      <button class="lab-filter-btn active" data-filter="all">Alles</button>
      <button class="lab-filter-btn" data-filter="app">Web Apps</button>
      <button class="lab-filter-btn" data-filter="ai">AI & Automatisering</button>
      <button class="lab-filter-btn" data-filter="branding">Branding</button>
      <button class="lab-filter-btn" data-filter="concept">Concepten</button>
    </div>
    <div class="lab-grid" id="labGrid">
      <a href="/case-cvw" class="lab-card reveal reveal-delay-1" data-tags="app">
        <div class="lab-card-thumb">
          <img src="https://images.unsplash.com/photo-1517048676732-d65bc937f952?q=80&w=800&auto=format&fit=crop" alt="CVW portaal" loading="lazy" />
          <div class="lab-card-thumb-overlay"></div>
          <div class="lab-card-badge">Medewerkersportaal</div>
        </div>
        <div class="lab-card-body">
          <div class="lab-card-name">Medewerkersportaal</div>
          <div class="lab-card-desc">Volledig maatwerk intern portaal voor 300+ medewerkers. Nieuws, vacatures, academie, meldpunt en spelmodule in één uitrol.</div>
          <div class="lab-card-chips"><span class="lab-chip">React</span><span class="lab-chip">Firebase</span><span class="lab-chip">PWA</span><span class="lab-chip">MVP op maat</span></div>
          <span class="lab-card-link">Bekijk case →</span>
        </div>
      </a>
      <a href="/case-buurtapp" class="lab-card reveal reveal-delay-2" data-tags="app">
        <div class="lab-card-thumb">
          <img src="https://images.unsplash.com/photo-1551650975-87deedd944c3?q=80&w=800&auto=format&fit=crop" alt="BuurtApp" loading="lazy" />
          <div class="lab-card-thumb-overlay"></div>
          <div class="lab-card-badge">Web App · White-label</div>
        </div>
        <div class="lab-card-body">
          <div class="lab-card-name">Web App · White-label</div>
          <div class="lab-card-desc">White-label meld- en buurtapp voor gemeentes en wijkteams. Kaartmodule, meldingen, chat en dossiers in één schaalbaar platform.</div>
          <div class="lab-card-chips"><span class="lab-chip">React</span><span class="lab-chip">Leaflet</span><span class="lab-chip">Firebase</span><span class="lab-chip">White-label</span></div>
          <span class="lab-card-link">Bekijk case →</span>
        </div>
      </a>
      <a href="/case-kluswinkel" class="lab-card reveal reveal-delay-3" data-tags="app">
        <div class="lab-card-thumb">
          <img src="https://images.unsplash.com/photo-1504307651254-35680f356dfd?q=80&w=800&auto=format&fit=crop" alt="Kluswinkel" loading="lazy" />
          <div class="lab-card-thumb-overlay"></div>
          <div class="lab-card-badge">Planning App</div>
        </div>
        <div class="lab-card-body">
          <div class="lab-card-name">Planning App</div>
          <div class="lab-card-desc">Planning board, werkbonnen, voertuigbeheer en klantafspraken gecentraliseerd. Gebouwd voor de dagelijkse operatie van een klusbedrijf.</div>
          <div class="lab-card-chips"><span class="lab-chip">React</span><span class="lab-chip">Firebase</span><span class="lab-chip">PWA</span></div>
          <span class="lab-card-link">Bekijk case →</span>
        </div>
      </a>
      <a href="/case-roasted-rebels" class="lab-card reveal reveal-delay-1" data-tags="branding concept">
        <div class="lab-card-thumb">
          <img src="https://images.unsplash.com/photo-1541462608143-67571c6738dd?q=80&w=800&auto=format&fit=crop" alt="Roasted Rebels" loading="lazy" />
          <div class="lab-card-thumb-overlay"></div>
          <div class="lab-card-badge">Concept · Branding</div>
        </div>
        <div class="lab-card-body">
          <div class="lab-card-name">Concept · Branding</div>
          <div class="lab-card-desc">Fictieve koffiebranderij voor nachtbrakers. Volledige merkidentiteit: fotografie, illustratie, branding en digital.</div>
          <div class="lab-card-chips"><span class="lab-chip">Branding</span><span class="lab-chip">Fotografie</span><span class="lab-chip">Illustratie</span></div>
          <span class="lab-card-link">Bekijk case →</span>
        </div>
      </a>
      <a href="/case-webbiecorn-os" class="lab-card reveal reveal-delay-2" data-tags="app ai">
        <div class="lab-card-thumb">
          <img src="https://images.unsplash.com/photo-1555949963-aa79dcee981c?q=80&w=800&auto=format&fit=crop" alt="Webbiecorn OS" loading="lazy" />
          <div class="lab-card-thumb-overlay"></div>
          <div class="lab-card-badge">Intern Tool</div>
        </div>
        <div class="lab-card-body">
          <div class="lab-card-name">Intern Tool</div>
          <div class="lab-card-desc">Onze eigen interne werkomgeving. Project management, klantoverzichten en AI-tooling samengebracht in één dashboard.</div>
          <div class="lab-card-chips"><span class="lab-chip">React</span><span class="lab-chip">n8n</span><span class="lab-chip">Intern</span></div>
          <span class="lab-card-link">Bekijk case →</span>
        </div>
      </a>
      <a href="/automatisering" class="lab-card reveal reveal-delay-3" data-tags="ai" style="background:linear-gradient(135deg,rgba(217,43,75,0.08),var(--black-card));border-color:rgba(217,43,75,0.2)">
        <div class="lab-card-thumb" style="background:var(--black);display:flex;align-items:center;justify-content:center;min-height:168px">
          <div style="text-align:center;padding:2rem">
            <div style="font-size:2.5rem;margin-bottom:0.75rem">🤖</div>
            <div style="font-size:0.8rem;font-weight:700;color:var(--red);letter-spacing:2px;text-transform:uppercase">AI & n8n</div>
          </div>
          <div class="lab-card-thumb-overlay"></div>
          <div class="lab-card-badge">Automatisering</div>
        </div>
        <div class="lab-card-body">
          <div class="lab-card-name">Automatisering</div>
          <div class="lab-card-desc">Van slimme notificatieflows tot volledige bedrijfsautomatisering met n8n en AI. Tijdwinst van dag één.</div>
          <div class="lab-card-chips"><span class="lab-chip">n8n</span><span class="lab-chip">AI</span><span class="lab-chip">Webhooks</span></div>
          <span class="lab-card-link">Bekijk mogelijkheden →</span>
        </div>
      </a>
    </div>
  </div>
</section>

<section style="background:var(--black-mid)">
  <div class="container">
    <div class="cta-banner reveal">
      <h2>Wil je ook in het lab?</h2>
      <p>Heb je een idee voor een app, tool of automatisering? We bouwen het. Van schets tot live platform.</p>
      <div class="btn-group">
        <a href="/contact" class="btn-primary">Start je project</a>
        <a href="/diensten" class="btn-ghost">Bekijk tarieven</a>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('astro:page-load', () => {
    const filterBtns = document.querySelectorAll('.lab-filter-btn');
    const labCards = document.querySelectorAll('#labGrid .lab-card');
    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const filter = btn.dataset.filter;
        labCards.forEach(card => {
          const tags = (card as HTMLElement).dataset.tags || '';
          const show = filter === 'all' || tags.includes(filter);
          (card as HTMLElement).style.display = show ? '' : 'none';
        });
      });
    });
  });
</script>
</Layout>

<script>
  // Terminal typing animation for Hero Title
  document.addEventListener('astro:page-load', () => {
    const textTarget = document.getElementById('typing-text');
    if (!textTarget) return;

    // The text content with emphasis encoded as a special token
    const phrases = [
      { text: "Digitale producten", isEm: false },
      { text: "<br/>", isBreak: true },
      { text: "die écht werken.", isEm: true }
    ];

    let currentPhrase = 0;
    let currentChar = 0;

    function typeWriter() {
      if (currentPhrase >= phrases.length) return;

      const phrase = phrases[currentPhrase];

      if (phrase.isBreak) {
        textTarget.innerHTML += "<br/>";
        currentPhrase++;
        setTimeout(typeWriter, 150);
        return;
      }

      if (currentChar === 0) {
        // Create the container for this phrase
        const span = document.createElement(phrase.isEm ? 'em' : 'span');
        span.id = `typing-phrase-${currentPhrase}`;
        textTarget.appendChild(span);
      }

      const curContainer = document.getElementById(`typing-phrase-${currentPhrase}`);
      curContainer.innerHTML += phrase.text.charAt(currentChar);
      currentChar++;

      if (currentChar < phrase.text.length) {
        // Randomize speed for realistic typing effect
        const speed = Math.random() * 50 + 40;
        setTimeout(typeWriter, speed);
      } else {
        // Next phrase
        currentPhrase++;
        currentChar = 0;
        setTimeout(typeWriter, 250); // Pause between lines
      }
    }

    // Start slightly delayed
    setTimeout(typeWriter, 800);
  });
</script>



---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Webbiecorn — Digitale producten die écht werken">

<div class="mobile-menu" id="mobileMenu">
  <a href="over.html" onclick="closeMobile()">Over ons</a>
  <a href="diensten.html" onclick="closeMobile()">Diensten</a>
  <a href="cases.html" onclick="closeMobile()">Cases</a>
  <a href="lab.html" onclick="closeMobile()">Lab</a>
  <a href="contact.html" onclick="closeMobile()" class="nav-cta-mobile">Start je project</a>
</div>

<!-- ═══════════════════════════════════════════
     HERO — Centered headline + 4 service cards
═══════════════════════════════════════════════ -->
<section id="hero-premium">
  <div class="aurora-bg">
    <div class="aurora-glow aurora-1"></div>
    <div class="aurora-glow aurora-2"></div>
    <div class="grid-overlay"></div>
  </div>
  
  <div class="hero-inner">
    <div class="avail-badge reveal-hero">
      <span class="pulsing-dot"></span>
      <span>Direct beschikbaar voor nieuwe projecten</span>
    </div>
    
    <h1 class="hero-title">
      <div class="text-line reveal-slide">Webbiecorn bouwt</div>
      <div class="text-line reveal-slide delay-1">digitale platformen met</div>
      <div class="text-line reveal-slide delay-2 hero-gradient-text">Ongekende Slagkracht.</div>
    </h1>
    
    <p class="hero-sub reveal-hero">
      Een gedreven team van technische experts. Wij combineren <span class="highlight">feilloze architectuur</span> met <span class="highlight">premium design</span> — voor organisaties die sneller en slimmer willen opereren.
    </p>
    
    <div class="hero-ctas reveal-hero">
      <a href="diensten.html" class="btn-primary magnetic-btn">
        <span class="btn-text">Start je project</span>
        <span class="btn-arrow">→</span>
      </a>
      <a href="cases.html" class="btn-ghost magnetic-btn">Bekijk het lab</a>
    </div>

    <div class="cards-stage reveal-hero">
      <div class="cards-row spotlight-group" id="premium-cards-row">
        
        <a href="apps.html" class="premium-card">
          <div class="spotlight"></div>
          <div class="card-content">
            <div class="card-icon">
              <svg width="26" height="26" viewBox="0 0 26 26" fill="none"><path d="M8 8 L2 13 L8 18" stroke="#D92B4B" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><path d="M18 8 L24 13 L18 18" stroke="#D92B4B" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><path d="M15.5 5 L10.5 21" stroke="#D92B4B" stroke-width="1.8" stroke-linecap="round"/></svg>
            </div>
            <h3>PWA's &amp; Apps</h3>
            <p>Razendsnelle maatwerk portals en web-apps. Zero bloatware, 100% performance.</p>
          </div>
        </a>

        <a href="automatisering.html" class="premium-card">
          <div class="spotlight"></div>
          <div class="card-content">
            <div class="card-icon">
              <svg width="26" height="26" viewBox="0 0 26 26" fill="none"><path d="M13 3 C7.477 3 3 7.477 3 13 S7.477 23 13 23 S23 18.523 23 13 S18.523 3 13 3Z" stroke="#D92B4B" stroke-width="1.8"/><path d="M13 8 L13 13 L16.5 16.5" stroke="#D92B4B" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><circle cx="19" cy="6" r="2.5" fill="#D92B4B" opacity="0.7"/></svg>
            </div>
            <h3>AI Workflows</h3>
            <p>Slimme AI & n8n automatisering die handmatige processen overbodig maakt.</p>
          </div>
        </a>

        <a href="design.html" class="premium-card">
          <div class="spotlight"></div>
          <div class="card-content">
            <div class="card-icon">
              <svg width="26" height="26" viewBox="0 0 26 26" fill="none"><rect x="2" y="2" width="9" height="9" rx="2" stroke="#D92B4B" stroke-width="1.8"/><rect x="15" y="2" width="9" height="9" rx="2" stroke="#D92B4B" stroke-width="1.8"/><rect x="2" y="15" width="9" height="9" rx="2" stroke="#D92B4B" stroke-width="1.8"/><rect x="15" y="15" width="9" height="9" rx="2" stroke="#D92B4B" stroke-width="1.8" opacity="0.35"/></svg>
            </div>
            <h3>UX/UI Design</h3>
            <p>Datagedreven interfaces en robuuste branding. Pixel-perfect ontworpen voor conversie.</p>
          </div>
        </a>

        <a href="onderhoud.html" class="premium-card">
          <div class="spotlight"></div>
          <div class="card-content">
            <div class="card-icon">
              <svg width="26" height="26" viewBox="0 0 26 26" fill="none"><path d="M13 2 L15.5 9H23L17 13.5L19.5 20.5L13 16L6.5 20.5L9 13.5L3 9H10.5Z" stroke="#D92B4B" stroke-width="1.8" stroke-linejoin="round"/></svg>
            </div>
            <h3>Managed Hosting</h3>
            <p>Actieve monitoring, dedicated infrastructuur en scherpe SLA-responstijden.</p>
          </div>
        </a>

      </div>
    </div>
  </div>
</section>

<!-- ═══ MARQUEE ══════════════════ -->
<!-- TECH STACK TICKER -->
<section id="tech-ticker">
  <div class="ticker-fade ticker-fade-left"></div>
  <div class="ticker-fade ticker-fade-right"></div>
  <div class="ticker-scroll">
    <div class="ticker-inner">
      <div class="ticker-item"><img src="https://upload.wikimedia.org/wikipedia/commons/a/a7/React-icon.svg" alt="React" width="20"/> React</div>
      <div class="ticker-item"><span class="dot pwa"></span> PWA's & Web Apps</div>
      <div class="ticker-item"><span class="dot n8n"></span> n8n AI Automatisering</div>
      <div class="ticker-item"><img src="https://upload.wikimedia.org/wikipedia/commons/3/37/Firebase_Logo.svg" alt="Firebase" width="20"/> Firebase</div>
      <div class="ticker-item"><img src="https://upload.wikimedia.org/wikipedia/commons/d/d5/Tailwind_CSS_Logo.svg" alt="Tailwind" width="20"/> Tailwind CSS</div>
      <div class="ticker-item"><span class="dot astro"></span> Astro Component Framework</div>
      <div class="ticker-item"><img src="https://upload.wikimedia.org/wikipedia/commons/d/d9/Node.js_logo.svg" alt="Node" width="40"/></div>
      
      <!-- Duplicate for seamless scrolling -->
      <div class="ticker-item"><img src="https://upload.wikimedia.org/wikipedia/commons/a/a7/React-icon.svg" alt="React" width="20"/> React</div>
      <div class="ticker-item"><span class="dot pwa"></span> PWA's & Web Apps</div>
      <div class="ticker-item"><span class="dot n8n"></span> n8n AI Automatisering</div>
      <div class="ticker-item"><img src="https://upload.wikimedia.org/wikipedia/commons/3/37/Firebase_Logo.svg" alt="Firebase" width="20"/> Firebase</div>
      <div class="ticker-item"><img src="https://upload.wikimedia.org/wikipedia/commons/d/d5/Tailwind_CSS_Logo.svg" alt="Tailwind" width="20"/> Tailwind CSS</div>
      <div class="ticker-item"><span class="dot astro"></span> Astro Component Framework</div>
      <div class="ticker-item"><img src="https://upload.wikimedia.org/wikipedia/commons/d/d9/Node.js_logo.svg" alt="Node" width="40"/></div>
    </div>
  </div>
</section>

<!-- ═══ STATS ═════════════════════ -->
<section id="stats-section">
  <div class="container">
    <div class="stats-grid">
      <div class="stat-item reveal">
        <div class="stat-number"><span class="stat-number-val" data-target="3">0</span><span class="stat-suffix">+</span></div>
        <div class="stat-label">Live platforms</div>
      </div>
      <div class="stat-item reveal reveal-delay-1">
        <div class="stat-number"><span class="stat-number-val" data-target="100">0</span><span class="stat-suffix">%</span></div>
        <div class="stat-label">Maatwerk</div>
      </div>
      <div class="stat-item reveal-hero">
        <div class="stat-number"><span class="stat-number-val" data-target="4">0</span><span class="stat-suffix"> wkn</span></div>
        <div class="stat-label">Gem. MVP Launchtijd</div>
      </div>
      <div class="stat-item reveal reveal-delay-3">
        <div class="stat-number"><span class="stat-number-val" data-target="4">0</span></div>
        <div class="stat-label">Disciplines onder één dak</div>
      </div>
    </div>
  </div>
</section>

<!-- ═══ WEBBIE GRID (Zo Werkt Het) ══════════════ -->
<section id="walkthrough-grid-section">
  <div class="container">
    <p class="section-label reveal-slide">Onze succesformule</p>
    <h2 class="section-title reveal-slide delay-1">Geen wollige trajecten.<br/><em class="hero-gradient-text">Pure executiekracht.</em></h2>
    <p class="section-sub reveal-slide delay-2">We bouwen in snelle iteraties. Vanaf de eerste schets tot aan de schaalbare live-omgeving, je hebt overal grip op.</p>

    <div class="bento-walkthrough reveal-slide delay-2">
      <!-- Stap 1 -->
      <div class="bento-card bento-large group-hover-trigger">
        <div class="bento-header">
          <div class="bento-number">01</div>
          <h3>Ontdekken &amp; Afkaderen</h3>
        </div>
        <p>Geen dikke rapporten, maar een scherpe intake. We definiëren de doelgroep en bepalen direct de MVP-scope en budget.</p>
        <div class="bento-visual">
          <div class="bento-pill">Scope bepaling</div>
          <div class="bento-pill highlight">Technische architectuur</div>
          <div class="bento-pill">Roadmap in kaart</div>
        </div>
      </div>

      <!-- Stap 2 -->
      <div class="bento-card bento-small">
        <div class="bento-header">
          <div class="bento-number">02</div>
          <h3>UX &amp; Prototype</h3>
        </div>
        <p>Je krijgt binnen no-time een interactief, klikbaar prototype in de huisstijl.</p>
        <div class="bento-visual-minimal">
          <div class="wireframe-box"></div>
          <div class="wireframe-box fill"></div>
        </div>
      </div>

      <!-- Stap 3 -->
      <div class="bento-card bento-small">
        <div class="bento-header">
          <div class="bento-number">03</div>
          <h3>Agile Development</h3>
        </div>
        <p>Transparante sprints. Korte lijntjes. Wekelijkse test-updates zonder verrassingen.</p>
        <div class="bento-visual-minimal code-style">
          <span>&lt;Code /&gt;</span>
        </div>
      </div>

      <!-- Stap 4 -->
      <div class="bento-card bento-large group-hover-trigger">
        <div class="bento-header">
          <div class="bento-number">04</div>
          <h3>Launch, Run &amp; Groei</h3>
        </div>
        <p>Live! We hosten je platform razendsnel, monitoren op uptime en blijven itereren voor groei.</p>
        <div class="bento-visual launch-visual">
          <div class="launch-graph">
            <div class="graph-bar w-1"></div>
            <div class="graph-bar w-2"></div>
            <div class="graph-bar w-3"></div>
            <div class="graph-bar w-4 highlight-bar"></div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ═══ LAB GRID ══════════════════ -->
<section id="lab-section">
  <div class="container">
    <p class="section-label reveal">Webbiecorn Lab</p>
    <h2 class="section-title reveal reveal-delay-1">Werk dat de<br/><em>norm verlegt.</em></h2>
    <p class="section-sub reveal reveal-delay-2">Van concept tot complexe app. Hier vind je de producten die we bouwden — elk met zijn eigen verhaal en aanpak.</p>
    <div class="lab-grid">
      <a href="case-cvw.html" class="lab-card reveal reveal-delay-1">
        <div class="lab-card-thumb">
          <img src="https://images.unsplash.com/photo-1517048676732-d65bc937f952?q=80&w=800&auto=format&fit=crop" alt="CVW portaal" loading="lazy" />
          <div class="lab-card-thumb-overlay"></div>
          <div class="lab-card-thumb-badge">Medewerkersportaal</div>
        </div>
        <div class="lab-card-body">
          <div class="lab-card-name">Concern voor Werk</div>
          <div class="lab-card-desc">Maatwerk intern portaal voor 300+ medewerkers. Nieuws, vacatures, academie, meldpunt en spelmodule in één uitrol.</div>
          <div class="lab-card-chips"><span class="lab-chip">React</span><span class="lab-chip">Firebase</span><span class="lab-chip">PWA</span><span class="lab-chip">MVP vanaf €4.5K</span></div>
          <span class="lab-card-link">Bekijk case →</span>
        </div>
      </a>
      <a href="case-buurtapp.html" class="lab-card reveal reveal-delay-2">
        <div class="lab-card-thumb">
          <img src="https://images.unsplash.com/photo-1551650975-87deedd944c3?q=80&w=800&auto=format&fit=crop" alt="BuurtApp" loading="lazy" />
          <div class="lab-card-thumb-overlay"></div>
          <div class="lab-card-thumb-badge">Web App</div>
        </div>
        <div class="lab-card-body">
          <div class="lab-card-name">BuurtApp v3.4</div>
          <div class="lab-card-desc">White-label meld- en buurtapp voor gemeentes en wijkteams. Kaartmodule, meldingen, chat en dossiers in één schaalbaar platform.</div>
          <div class="lab-card-chips"><span class="lab-chip">React</span><span class="lab-chip">Leaflet</span><span class="lab-chip">Firebase</span><span class="lab-chip">White-label</span></div>
          <span class="lab-card-link">Bekijk case →</span>
        </div>
      </a>
      <a href="case-kluswinkel.html" class="lab-card reveal reveal-delay-3">
        <div class="lab-card-thumb">
          <img src="https://images.unsplash.com/photo-1504307651254-35680f356dfd?q=80&w=800&auto=format&fit=crop" alt="Kluswinkel app" loading="lazy" />
          <div class="lab-card-thumb-overlay"></div>
          <div class="lab-card-thumb-badge">Planning App</div>
        </div>
        <div class="lab-card-body">
          <div class="lab-card-name">Kluswinkel App</div>
          <div class="lab-card-desc">Planning board, werkbonnen, voertuigbeheer en klantafspraken gecentraliseerd. Gebouwd voor de dagelijkse operatie.</div>
          <div class="lab-card-chips"><span class="lab-chip">React</span><span class="lab-chip">Firebase</span><span class="lab-chip">PWA</span></div>
          <span class="lab-card-link">Bekijk case →</span>
        </div>
      </a>
      <a href="case-roasted-rebels.html" class="lab-card reveal reveal-delay-1">
        <div class="lab-card-thumb">
          <img src="https://images.unsplash.com/photo-1541462608143-67571c6738dd?q=80&w=800&auto=format&fit=crop" alt="Roasted Rebels" loading="lazy" />
          <div class="lab-card-thumb-overlay"></div>
          <div class="lab-card-thumb-badge">Concept · Branding</div>
        </div>
        <div class="lab-card-body">
          <div class="lab-card-name">Roasted Rebels</div>
          <div class="lab-card-desc">Fictieve koffiebranderij voor nachtbrakers. Volledige merkidentiteit: fotografie, illustratie, branding en digital.</div>
          <div class="lab-card-chips"><span class="lab-chip">Branding</span><span class="lab-chip">Fotografie</span><span class="lab-chip">Illustratie</span></div>
          <span class="lab-card-link">Bekijk case →</span>
        </div>
      </a>
      <a href="case-webbiecorn-os.html" class="lab-card reveal reveal-delay-2">
        <div class="lab-card-thumb">
          <img src="https://images.unsplash.com/photo-1555949963-aa79dcee981c?q=80&w=800&auto=format&fit=crop" alt="Webbiecorn OS" loading="lazy" />
          <div class="lab-card-thumb-overlay"></div>
          <div class="lab-card-thumb-badge">Intern Tool</div>
        </div>
        <div class="lab-card-body">
          <div class="lab-card-name">Webbiecorn OS</div>
          <div class="lab-card-desc">Onze eigen interne werkomgeving. Project management, klantoverzichten en AI-tooling samengebracht in één dashboard.</div>
          <div class="lab-card-chips"><span class="lab-chip">React</span><span class="lab-chip">n8n</span><span class="lab-chip">Intern</span></div>
          <span class="lab-card-link">Bekijk case →</span>
        </div>
      </a>
      <a href="automatisering.html" class="lab-card reveal reveal-delay-3" style="background:linear-gradient(135deg,rgba(217,43,75,0.07),var(--black-card));border-color:rgba(217,43,75,0.18)">
        <div class="lab-card-thumb" style="background:var(--black);display:flex;align-items:center;justify-content:center">
          <div style="text-align:center;padding:2rem">
            <div style="font-size:2.5rem;margin-bottom:0.6rem">🤖</div>
            <div style="font-size:0.72rem;font-weight:700;color:var(--red);letter-spacing:2px;text-transform:uppercase">AI &amp; n8n</div>
          </div>
          <div class="lab-card-thumb-overlay"></div>
          <div class="lab-card-thumb-badge">Automatisering</div>
        </div>
        <div class="lab-card-body">
          <div class="lab-card-name">AI Workflows op maat</div>
          <div class="lab-card-desc">Van slimme notificatieflows tot volledige bedrijfsautomatisering met n8n en AI. Tijdwinst van dag één.</div>
          <div class="lab-card-chips"><span class="lab-chip">n8n</span><span class="lab-chip">AI</span><span class="lab-chip">Webhooks</span><span class="lab-chip">Integraties</span></div>
          <span class="lab-card-link">Bekijk mogelijkheden →</span>
        </div>
      </a>
    </div>
    <div style="text-align:center;margin-top:3rem">
      <a href="lab.html" class="btn-ghost reveal">Bekijk het volledige lab →</a>
    </div>
  </div>
</section>

<!-- ═══ OVER TEASER ═══════════════ -->
<section id="over-teaser">
  <div class="container">
    <div class="over-grid">
      <div>
        <p class="section-label reveal">Over Webbiecorn</p>
        <h2 class="section-title reveal reveal-delay-1">Vergeet de<br/><em>traditionele bureaus.</em></h2>
        <div class="over-card reveal reveal-delay-2">
          <p>Wij zijn Webbiecorn. Een compact bureau dat design, techniek en beheer combineert in een strak uitvoerbaar traject. Van eerste concept tot live platform.</p>
          <p>Geen trage trajecten, geen vage offertes, geen overhead-circus. Wij bouwen digitale producten die processen versimpelen en organisaties direct vooruithelpen.</p>
        </div>
        <a href="over.html" class="teaser-link reveal reveal-delay-3">Lees ons verhaal →</a>
      </div>
      <div class="team-grid reveal reveal-delay-3">
        <div class="team-member"><div class="team-avatar">✦</div><div><div class="team-name">Creative Direction</div><div class="team-role">Branding · UX/UI · Contentproductie</div></div></div>
        <div class="team-member"><div class="team-avatar">✦</div><div><div class="team-name">Tech &amp; Strategy</div><div class="team-role">PWA's · Automatisering · Managed Hosting</div></div></div>
      </div>
    </div>
  </div>
</section>

<!-- ═══ CASES CAROUSEL ══════════════════ -->
<section id="cases-carousel" class="reveal">
  <div class="container">
    <p class="section-label">Recente Impact</p>
    <h2 class="section-title">Uitgelichte<br/><em>Cases.</em></h2>
    <div class="carousel-container">
      <div class="carousel-track">
        <a href="case-buurtapp.html" class="carousel-card">
          <div class="carousel-img">
            <img src="https://images.unsplash.com/photo-1551650975-87deedd944c3?q=80&w=800&auto=format&fit=crop" loading="lazy" alt="BuurtApp">
          </div>
          <div class="carousel-content">
            <h3>BuurtApp v3.4</h3>
            <p>Meld- en buurtapp voor gemeentes en wijkteams.</p>
          </div>
        </a>
        <a href="case-cvw.html" class="carousel-card">
          <div class="carousel-img">
            <img src="https://images.unsplash.com/photo-1517048676732-d65bc937f952?q=80&w=800&auto=format&fit=crop" loading="lazy" alt="CVW">
          </div>
          <div class="carousel-content">
            <h3>Concern voor Werk</h3>
            <p>Maatwerk intern portaal voor 300+ medewerkers.</p>
          </div>
        </a>
        <a href="case-kluswinkel.html" class="carousel-card">
          <div class="carousel-img">
            <img src="https://images.unsplash.com/photo-1504307651254-35680f356dfd?q=80&w=800&auto=format&fit=crop" loading="lazy" alt="Kluswinkel">
          </div>
          <div class="carousel-content">
            <h3>Kluswinkel App</h3>
            <p>Planning board, werkbonnen en voertuigbeheer app.</p>
          </div>
        </a>
        <a href="case-webbiecorn-os.html" class="carousel-card">
          <div class="carousel-img">
            <img src="https://images.unsplash.com/photo-1555949963-aa79dcee981c?q=80&w=800&auto=format&fit=crop" loading="lazy" alt="Webbiecorn OS">
          </div>
          <div class="carousel-content">
            <h3>Webbiecorn OS</h3>
            <p>Interne werkomgeving met slimme AI-tooling en n8n workflows.</p>
          </div>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ═══ CTA ════════════════════════ -->
<section id="cta-section">
  <div class="container">
    <div class="cta-banner reveal">
      <h2>Klaar voor de volgende stap?</h2>
      <p>Laten we het hebben over jouw project. Geen eindeloze brainstorms, maar concrete plannen en tastbaar resultaat.</p>
      <div class="btn-group">
        <a href="contact.html" class="btn-primary">Start je project</a>
        <a href="diensten.html" class="btn-ghost">Bekijk tarieven</a>
      </div>
    </div>
  </div>
</section>

<style>
  /* Typing animation */
  .blinking-cursor {
    display: inline-block;
    width: 0.6em;
    height: 1.2em;
    background-color: var(--red, #D92B4B);
    vertical-align: text-bottom;
    margin-left: 2px;
    animation: blink 1s step-end infinite;
  }
  @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

  /* Cases Carousel */
  #cases-carousel {
    padding: 6rem 0;
    overflow: hidden;
  }
  .carousel-container {
    margin-top: 3rem;
  }
  .carousel-track {
    display: flex;
    gap: 1.5rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding-bottom: 2rem;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    overscroll-behavior-x: contain;
  }
  .carousel-track::-webkit-scrollbar {
    height: 8px;
  }
  .carousel-track::-webkit-scrollbar-track {
    background: rgba(255,255,255,0.05);
    border-radius: 4px;
  }
  .carousel-track::-webkit-scrollbar-thumb {
    background: rgba(217, 43, 75, 0.4);
    border-radius: 4px;
  }
  .carousel-card {
    flex: 0 0 300px;
    scroll-snap-align: center;

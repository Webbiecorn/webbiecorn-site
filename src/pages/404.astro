---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Pagina niet gevonden — Webbiecorn" description="Deze pagina bestaat niet.">
<style>
  body { display: flex; flex-direction: column; min-height: 100vh; }
  .not-found {
    flex: 1; display: flex; align-items: center; justify-content: center;
    text-align: center; padding: 6rem 2rem; background: var(--black);
  }
  .not-found-inner { max-width: 560px; }
  .not-found-code {
    font-size: clamp(5rem, 18vw, 10rem); font-weight: 800;
    line-height: 1; letter-spacing: -6px;
    color: transparent;
    -webkit-text-stroke: 2px rgba(217,43,75,0.5);
    margin-bottom: 1rem;
  }
  .not-found-inner h1 {
    font-size: clamp(1.5rem, 4vw, 2.2rem); font-weight: 700;
    margin-bottom: 1rem;
  }
  .not-found-inner p {
    color: rgba(255,255,255,0.45); line-height: 1.7; margin-bottom: 2.5rem;
  }
  .not-found-links { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
</style>

<div class="not-found">
  <div class="not-found-inner">
    <div class="not-found-code">404</div>
    <h1>Deze pagina bestaat niet.</h1>
    <p>Misschien is de URL veranderd, of heb je een typfout gemaakt. Geen paniek — het lab is nog gewoon open.</p>
    <div class="not-found-links">
      <a href="/" class="btn-primary">Terug naar home</a>
      <a href="/cases" class="btn-ghost">Bekijk het lab</a>
    </div>
  </div>
</div>
</Layout>

---
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title?: string;
}

const { title = "Webbiecorn — Digitale producten die écht werken" } = Astro.props;
---

<!DOCTYPE html>
<html lang="nl">
<head>

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content="Webbiecorn bouwt PWA's, AI-automatisering en maatwerk portals voor organisaties die willen doorpakken. Van eerste schets tot live platform." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://webbiecorn.com/" />
  <meta property="og:title" content="Webbiecorn — Digitale producten die écht werken" />
  <meta property="og:description" content="Maatwerk PWA's, AI-workflows en strak design. Bekijk live demo's van onze apps." />
  <meta property="og:image" content="https://webbiecorn.com/og-image.png" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="theme-color" content="#0d0d0d" />
  <link rel="canonical" href="https://webbiecorn.com/" />
  <link rel="apple-touch-icon" href="/webbiecorn-logo.png" />
  <link rel="icon" type="image/png" href="/webbiecorn-logo.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800;900&family=Open+Sans:wght@400;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/style.css" />
  <!-- GSAP + ScrollTrigger -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" defer></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" defer></script>
  <style>
    /* ── HERO ─────────────────────────────────── */
    #hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      align-items: center;
      overflow: hidden;
      background: var(--black);
    }
    canvas#particles {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      z-index: 0;
      pointer-events: none;
    }
    .hero-inner {
      position: relative; z-index: 2;
      width: 100%; max-width: 1160px;
      margin: 0 auto;
      padding: 7rem 2rem 5rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .avail-badge {
      display: inline-flex; align-items: center; gap: 0.5rem;
      font-size: 0.72rem; font-weight: 700;
      letter-spacing: 2px; text-transform: uppercase;
      color: rgba(255,255,255,0.55);
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 100px;
      padding: 0.45rem 1.1rem;
      margin-bottom: 1.75rem;
    }
    .avail-dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: #4ade80;
      box-shadow: 0 0 0 0 rgba(74,222,128,0.5);
      animation: pulse-dot 2s ease-in-out infinite;
      flex-shrink: 0;
    }
    @keyframes pulse-dot {
      0%,100%{box-shadow:0 0 0 0 rgba(74,222,128,0.5)}
      50%{box-shadow:0 0 0 6px rgba(74,222,128,0)}
    }
    .hero-eyebrow {
      display: inline-block;
      font-size: 0.7rem; font-weight: 700;
      letter-spacing: 3px; text-transform: uppercase;
      color: var(--red);
      border: 1px solid rgba(217,43,75,0.4);
      border-radius: 3px;
      padding: 0.3rem 0.9rem;
      margin-bottom: 1.5rem;
    }
    .hero-title {
      font-size: clamp(3rem, 6.5vw, 5.5rem);
      font-weight: 900;
      line-height: 1.0;
      letter-spacing: -2px;
      margin-bottom: 1.5rem;
      max-width: 820px;
    }
    .hero-title em { font-style: normal; color: var(--red); }
    .hero-sub {
      font-size: clamp(1rem, 2vw, 1.15rem);
      color: rgba(255,255,255,0.55);
      line-height: 1.75;
      max-width: 600px;
      margin: 0 auto 2.5rem;
    }
    .hero-ctas { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; margin-bottom: 0; }

    /* ── SERVICE CARDS STAGE ─────────────────── */
    .cards-stage {
      margin-top: 5rem;
      width: 100%;
      perspective: 1200px;
      perspective-origin: 50% 20%;
    }
    .cards-row {
      display: flex;
      gap: 1.25rem;
      justify-content: center;
      transform: rotateX(22deg);
      transform-style: preserve-3d;
      will-change: transform;
      padding-bottom: 3rem;
    }
    .stage-card {
      flex: 0 0 auto;
      width: 220px;
      background: rgba(14,14,14,0.95);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 20px;
      padding: 2.1rem 1.5rem 1.75rem;
      backdrop-filter: blur(24px);
      transform-style: preserve-3d;
      transition: transform 0.4s cubic-bezier(0.34,1.56,0.64,1), border-color 0.3s, box-shadow 0.3s;
      cursor: default;
      position: relative;
      overflow: hidden;
      text-decoration: none;
      color: inherit;
    }
    .stage-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(217,43,75,0.1) 0%, transparent 60%);
      opacity: 0;
      transition: opacity 0.3s;
      border-radius: inherit;
      pointer-events: none;
    }
    .stage-card:hover {
      transform: translateZ(55px) rotateX(-4deg);
      border-color: rgba(217,43,75,0.55);
      box-shadow: 0 0 40px rgba(217,43,75,0.25), 0 28px 70px rgba(0,0,0,0.7);
    }
    .stage-card:hover::before { opacity: 1; }
    .card-bar {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 2px;
      background: var(--red);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.35s ease;
    }
    .stage-card:hover .card-bar { transform: scaleX(1); }
    .card-icon {
      width: 48px; height: 48px;
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 1.25rem;
      background: rgba(217,43,75,0.09);
      border: 1px solid rgba(217,43,75,0.18);
      border-radius: 14px;
    }
    .stage-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 0.5rem; color: #fff; }
    .stage-card p { font-size: 0.78rem; color: rgba(255,255,255,0.42); line-height: 1.65; }

    /* ── MARQUEE ─────────────────────────────── */
    #over-teaser { background: var(--black-mid); }
    #cta-section { background: var(--black); padding: 5rem 2rem; }

    /* ── STATS ───────────────────────────────── */
    #stats-section {
      background: var(--black-mid);
      padding: 5rem 2rem;
      position: relative;
    }
    #stats-section::before, #stats-section::after {
      content: '';
      position: absolute;
      left: 0; right: 0; height: 1px;
      background: linear-gradient(90deg, transparent, rgba(217,43,75,0.2), transparent);
    }
    #stats-section::before { top: 0; }
    #stats-section::after { bottom: 0; }
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 2rem;
      max-width: 800px; margin: 0 auto;
      text-align: center;
    }
    .stat-number {
      font-size: clamp(2.5rem, 5vw, 3.5rem);
      font-weight: 900; line-height: 1;
      background: linear-gradient(135deg, #fff 0%, rgba(255,255,255,0.55) 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .stat-suffix { color: var(--red); -webkit-text-fill-color: var(--red); }
    .stat-label {
      font-size: 0.72rem; font-weight: 700;
      letter-spacing: 2px; text-transform: uppercase;
      color: rgba(255,255,255,0.3); margin-top: 0.5rem;
    }

    /* ── WALKTHROUGH ─────────────────────────── */
    #walkthrough {
      background: var(--black-mid);
      padding: 7rem 2rem;
      position: relative; overflow: hidden;
    }
    #walkthrough::after {
      content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 1px;
      background: linear-gradient(90deg, transparent, rgba(217,43,75,0.25), transparent);
    }
    .walkthrough-grid {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 5rem; align-items: center; margin-top: 4rem;
    }
    .walkthrough-steps { display: flex; flex-direction: column; gap: 0; }
    .wt-step {
      display: flex; gap: 1.5rem;
      padding: 1.4rem; border-radius: 12px;
      cursor: pointer; transition: background 0.3s;
      border: 1px solid transparent;
    }
    .wt-step.active { background: rgba(217,43,75,0.06); border-color: rgba(217,43,75,0.16); }
    .wt-step-nr {
      width: 34px; height: 34px; border-radius: 50%;
      border: 2px solid rgba(217,43,75,0.3);
      display: flex; align-items: center; justify-content: center;
      font-size: 0.78rem; font-weight: 800; color: var(--red);
      flex-shrink: 0; transition: background 0.3s, border-color 0.3s;
    }
    .wt-step.active .wt-step-nr { background: var(--red); border-color: var(--red); color: #fff; }
    .wt-step-title {
      font-size: 0.93rem; font-weight: 700; margin-bottom: 0.3rem;
      color: rgba(255,255,255,0.6); transition: color 0.3s;
    }
    .wt-step.active .wt-step-title { color: #fff; }
    .wt-step-desc {
      font-size: 0.82rem; color: rgba(255,255,255,0.38);
      line-height: 1.65; max-height: 0; overflow: hidden;
      transition: max-height 0.4s ease, opacity 0.3s; opacity: 0;
    }
    .wt-step.active .wt-step-desc { max-height: 200px; opacity: 1; }
    .wt-connector { width: 2px; height: 18px; background: rgba(217,43,75,0.12); margin-left: calc(1.5rem + 16px); transition: background 0.4s ease; }
    .wt-connector.active { background: #D92B4B; }
    .wt-screen {
      position: relative; background: #111;
      border-radius: 24px; border: 2px solid rgba(255,255,255,0.08);
      overflow: hidden; aspect-ratio: 9/16; max-height: 540px;
      box-shadow: 0 40px 100px rgba(0,0,0,0.6), 0 0 50px rgba(217,43,75,0.07);
    }
    .wt-panel {
      position: absolute; inset: 0; padding: 2.5rem 1.25rem 1.25rem;
      opacity: 0; transform: translateY(12px);
      transition: opacity 0.5s cubic-bezier(0.2, 0.8, 0.2, 1), transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1); pointer-events: none;
    }
    .wt-panel.active { opacity: 1; transform: none; pointer-events: auto; }

    /* Micro-animations in panels */
    .wt-check-item, .wt-fake-input, .wt-notification {
      opacity: 0; transform: translateY(8px);
      transition: opacity 0.4s ease, transform 0.4s ease;
    }
    .wt-panel.active .wt-check-item,
    .wt-panel.active .wt-fake-input,
    .wt-panel.active .wt-notification {
      opacity: 1; transform: none;
    }
    .wt-panel.active .wt-check-item:nth-child(1) { transition-delay: 0.15s; }
    .wt-panel.active .wt-check-item:nth-child(2) { transition-delay: 0.25s; }
    .wt-panel.active .wt-check-item:nth-child(3) { transition-delay: 0.35s; }
    .wt-panel.active .wt-fake-input:nth-child(2) { transition-delay: 0.15s; }
    .wt-panel.active .wt-fake-input:nth-child(3) { transition-delay: 0.25s; }
    .wt-panel.active .wt-fake-input:nth-child(4) { transition-delay: 0.35s; }
    .wt-panel.active .wt-notification:nth-child(2) { transition-delay: 0.15s; }
    .wt-panel.active .wt-notification:nth-child(3) { transition-delay: 0.30s; }
    .wt-notch {
      position: absolute; top: 8px; left: 50%; transform: translateX(-50%);
      width: 70px; height: 18px; background: #080808; border-radius: 100px; z-index: 10;
    }
    .wt-panel-header {
      font-size: 0.83rem; font-weight: 800; color: #fff;
      margin-bottom: 1rem; margin-top: 0.5rem;
      display: flex; align-items: center; gap: 0.55rem;
    }
    .wt-panel-header-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--red); box-shadow: 0 0 8px rgba(217,43,75,0.7); }
    .wt-bar { height: 6px; border-radius: 100px; background: rgba(255,255,255,0.05); margin-bottom: 0.4rem; overflow: hidden; }
    .wt-bar-fill { height: 100%; background: var(--red); border-radius: 100px; }
    .wt-fake-input {
      background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
      border-radius: 8px; padding: 0.55rem 0.7rem;
      font-size: 0.68rem; color: rgba(255,255,255,0.55);
      margin-bottom: 0.45rem; display: flex; align-items: center; gap: 0.45rem;
    }
    .wt-fake-input-icon { color: var(--red); }
    .wt-check-list { display: flex; flex-direction: column; gap: 0.4rem; }
    .wt-check-item {
      display: flex; align-items: center; gap: 0.5rem;
      font-size: 0.68rem; color: rgba(255,255,255,0.65);
      padding: 0.45rem 0.6rem;
      background: rgba(255,255,255,0.03); border-radius: 7px;
    }
    .wt-check-icon { color: #4ade80; font-weight: 700; flex-shrink: 0; }
    .wt-notification {
      background: rgba(217,43,75,0.1); border: 1px solid rgba(217,43,75,0.22);
      border-radius: 10px; padding: 0.7rem;
      display: flex; gap: 0.55rem; align-items: flex-start; margin-bottom: 0.45rem;
    }
    .wt-notification-title { font-size: 0.68rem; font-weight: 700; color: #fff; margin-bottom: 0.18rem; }
    .wt-notification-body { font-size: 0.6rem; color: rgba(255,255,255,0.48); line-height: 1.5; }
    .wt-progress {
      position: absolute; bottom: 14px; left: 50%; transform: translateX(-50%);
      display: flex; gap: 6px; z-index: 20;
    }
    .wt-progress-dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: rgba(255,255,255,0.18);
      transition: background 0.3s, transform 0.3s; cursor: pointer;
    }
    .wt-progress-dot.active { background: var(--red); transform: scale(1.4); }

    /* ── LAB SECTION ─────────────────────────── */
    #lab-section { background: var(--black); padding: 7rem 2rem; }
    .lab-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 1.5rem; margin-top: 3rem;
    }
    .lab-card {
      background: var(--black-card); border: 1px solid var(--border);
      border-radius: 16px; overflow: hidden;
      text-decoration: none; color: var(--white);
      transition: transform 0.3s, border-color 0.3s, box-shadow 0.3s;
      position: relative;
    }
    .lab-card::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
      background: var(--red); transform: scaleX(0); transform-origin: left;
      transition: transform 0.35s ease;
    }
    .lab-card:hover { transform: translateY(-6px); border-color: rgba(217,43,75,0.35); box-shadow: 0 20px 60px rgba(217,43,75,0.09); }
    .lab-card:hover::before { transform: scaleX(1); }
    .lab-card-thumb { width: 100%; aspect-ratio: 16/9; background: var(--black-mid); overflow: hidden; position: relative; }
    .lab-card-thumb img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease; }
    .lab-card:hover .lab-card-thumb img { transform: scale(1.05); }
    .lab-card-thumb-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(10,10,10,0.65), transparent 50%); }
    .lab-card-thumb-badge {
      position: absolute; top: 1rem; left: 1rem;
      font-size: 0.6rem; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase;
      padding: 0.28rem 0.65rem; border-radius: 100px;
      background: rgba(10,10,10,0.85); border: 1px solid rgba(255,255,255,0.1);
      color: rgba(255,255,255,0.65); backdrop-filter: blur(8px);
    }
    .lab-card-body { padding: 1.4rem; }
    .lab-card-name { font-size: 1.05rem; font-weight: 700; margin-bottom: 0.45rem; }
    .lab-card-desc { font-size: 0.82rem; color: rgba(255,255,255,0.48); line-height: 1.65; margin-bottom: 1.1rem; }
    .lab-card-chips { display: flex; flex-wrap: wrap; gap: 0.35rem; }
    .lab-chip {
      font-size: 0.63rem; font-weight: 700; letter-spacing: 0.5px;
      padding: 0.18rem 0.55rem;
      background: rgba(217,43,75,0.08); border: 1px solid rgba(217,43,75,0.18);
      border-radius: 100px; color: rgba(255,255,255,0.55);
    }
    .lab-card-link {
      display: inline-flex; align-items: center; gap: 0.35rem;
      margin-top: 0.9rem; color: var(--red); font-size: 0.78rem; font-weight: 700;
      transition: gap 0.2s;
    }
    .lab-card:hover .lab-card-link { gap: 0.6rem; }

    /* ── RESPONSIVE ──────────────────────────── */
    @media (max-width: 900px) {
      .cards-row { transform: none; flex-wrap: wrap; gap: 1rem; }
      .stage-card { width: calc(50% - 0.5rem); }
      .walkthrough-grid { grid-template-columns: 1fr; }
      .wt-screen { max-height: 380px; }
    }
    @media (max-width: 500px) {
      .stage-card { width: 100%; }
    }
  </style>

  <ViewTransitions />
</head>
<body class="fade-in">
  <div id="scroll-progress"></div>
  <div id="cursor-spotlight"></div>

<nav id="navbar">
  <a href="/" class="nav-logo">
    <img src="/webbiecorn-logo.png" alt="Webbiecorn logo" class="nav-logo-icon" />
